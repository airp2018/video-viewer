{
  "manifest_version": 3,
  "name": "Video Viewer",
  "version": "1.0.0",
  "description": "Video viewer assistant for YouTube and Bilibili with subtitles and AI summaries",
  "permissions": [
    "storage",
    "activeTab",
    "downloads",
    "scripting",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://www.youtube.com/*",
    "https://youtubei.googleapis.com/*",
    "https://*.bilibili.com/*",
    "https://api.bilibili.com/*",
    "https://upos-sz-mirrorakam.bilivideo.com/*",
    "https://upos-sz-mirrorcoso1.bilivideo.com/*",
    "https://upos-sz-mirrorcos.bilivideo.com/*",
    "https://upos-sz-mirrorhw.bilivideo.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.siliconflow.cn/*",
    "https://api.supadata.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*"
      ],
      "js": ["youtube/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://www.bilibili.com/video/*"],
      "js": ["bilibili/content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Video Viewer",
    "default_icon": {
      "16": "youtube/icons/icon16.png",
      "32": "youtube/icons/icon32.png",
      "48": "youtube/icons/icon48.png",
      "128": "youtube/icons/icon128.png"
    }
  },
  "icons": {
    "16": "youtube/icons/icon16.png",
    "32": "youtube/icons/icon32.png",
    "48": "youtube/icons/icon48.png",
    "128": "youtube/icons/icon128.png"
  },
  "side_panel": {
    "default_path": "router.html"
  }
}
